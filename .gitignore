# Root gitignore

# Environment files - NEVER commit these
.env
.env.local
.env.*.local

# Node modules
node_modules/

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/
